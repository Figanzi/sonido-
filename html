<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Figanzi Sonidos — Producción de eventos</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --red: #D1000A;
      --red-dark: #A0000A;
      --red-glow: rgba(209,0,10,0.15);
      --bg: #F4F4F2;
      --surface: #FFFFFF;
      --surface2: #EBEBEA;
      --border: rgba(0,0,0,0.1);
      --text: #111111;
      --muted: #666666;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-weight: 300;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── WHATSAPP FLOTANTE ── */
    .wa-float {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      z-index: 999;
      background: #25D366;
      color: #fff;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 20px rgba(37,211,102,0.4);
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .wa-float:hover {
      transform: scale(1.1);
      box-shadow: 0 6px 28px rgba(37,211,102,0.55);
    }
    .wa-float svg { width: 28px; height: 28px; fill: #fff; }

    /* ── HERO ── */
    header {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem;
      overflow: hidden;
      background: #111;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 65% 55% at 50% 40%, rgba(209,0,10,0.28) 0%, transparent 70%);
    }

    .wave {
      position: absolute;
      bottom: 0;
      left: 0; right: 0;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      gap: 3px;
      height: 130px;
      padding: 0 1rem;
      opacity: 0.2;
    }
    .wave span {
      flex: 1;
      max-width: 7px;
      background: var(--red);
      border-radius: 2px 2px 0 0;
      animation: pulse 1.4s ease-in-out infinite alternate;
    }
    .wave span:nth-child(odd)  { animation-duration: 1.1s; }
    .wave span:nth-child(3n)   { animation-duration: 1.7s; }
    .wave span:nth-child(5n)   { animation-duration: 0.9s; }
    @keyframes pulse {
      from { transform: scaleY(0.15); }
      to   { transform: scaleY(1); }
    }

    .hero-content {
      position: relative;
      z-index: 1;
      animation: fadeUp 0.9s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(32px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .logo-tag {
      display: inline-block;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.82rem;
      letter-spacing: 0.38em;
      color: var(--red);
      border: 1px solid var(--red);
      padding: 0.3rem 1.1rem;
      margin-bottom: 2rem;
    }

    h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3.8rem, 12vw, 10rem);
      line-height: 0.9;
      letter-spacing: 0.02em;
      color: #fff;
    }
    h1 span { color: var(--red); display: block; }

    .hero-sub {
      margin-top: 1.6rem;
      font-size: 1rem;
      color: rgba(255,255,255,0.6);
      max-width: 400px;
      line-height: 1.75;
    }

    .hero-btns {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 2.5rem;
    }

    .cta-btn {
      display: inline-block;
      background: var(--red);
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-weight: 500;
      font-size: 0.9rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.95rem 2.5rem;
      border: none;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 0 28px var(--red-glow);
    }
    .cta-btn:hover {
      background: var(--red-dark);
      transform: translateY(-2px);
      box-shadow: 0 0 45px rgba(209,0,10,0.4);
    }
    .cta-btn-outline {
      display: inline-block;
      background: transparent;
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-weight: 500;
      font-size: 0.9rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.95rem 2.5rem;
      border: 1px solid rgba(255,255,255,0.3);
      cursor: pointer;
      text-decoration: none;
      transition: border-color 0.2s, background 0.2s;
    }
    .cta-btn-outline:hover {
      border-color: #fff;
      background: rgba(255,255,255,0.07);
    }

    .scroll-hint {
      position: absolute;
      bottom: 2.2rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4rem;
      color: rgba(255,255,255,0.3);
      font-size: 0.68rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }
    .scroll-hint .line {
      width: 1px; height: 36px;
      background: linear-gradient(to bottom, var(--red), transparent);
      animation: scrollLine 1.7s ease-in-out infinite;
    }
    @keyframes scrollLine {
      0%   { opacity: 0; transform: scaleY(0); transform-origin: top; }
      50%  { opacity: 1; }
      100% { opacity: 0; transform: scaleY(1); transform-origin: top; }
    }

    /* ── SECTIONS ── */
    section {
      position: relative;
      z-index: 1;
      padding: 5.5rem 2rem;
      max-width: 940px;
      margin: 0 auto;
    }

    .section-label {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 0.78rem;
      letter-spacing: 0.38em;
      color: var(--red);
      margin-bottom: 0.8rem;
    }
    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2rem, 5vw, 3.2rem);
      line-height: 1;
      color: var(--text);
      margin-bottom: 0.6rem;
    }
    .section-sub {
      font-size: 0.9rem;
      color: var(--muted);
      line-height: 1.7;
      max-width: 520px;
    }

    /* ── EQUIPMENT GRID ── */
    .equip-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      margin-top: 3rem;
    }
    .equip-card {
      background: var(--surface);
      padding: 1.8rem 1.5rem;
      transition: background 0.2s;
    }
    .equip-card:hover { background: var(--surface2); }
    .equip-icon { font-size: 1.6rem; margin-bottom: 0.8rem; }
    .equip-card h3 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.15rem;
      letter-spacing: 0.04em;
      margin-bottom: 0.4rem;
      color: var(--text);
    }
    .equip-card p { font-size: 0.84rem; color: var(--muted); line-height: 1.6; }

    /* ── WHY US ── */
    .why-section { background: #111; }
    .why-inner {
      max-width: 940px;
      margin: 0 auto;
      padding: 5.5rem 2rem;
    }
    .why-section .section-title { color: #fff; }
    .why-section .section-label { color: var(--red); }
    .why-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }
    .why-item { border-left: 3px solid var(--red); padding-left: 1.2rem; }
    .why-item h4 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.2rem;
      color: #fff;
      margin-bottom: 0.4rem;
      letter-spacing: 0.03em;
    }
    .why-item p { font-size: 0.86rem; color: rgba(255,255,255,0.5); line-height: 1.65; }

    /* ── STEPS ── */
    .steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.4rem;
      margin-top: 3rem;
    }
    .step {
      background: var(--surface);
      border: 1px solid var(--border);
      border-top: 3px solid var(--red);
      padding: 2rem 1.5rem;
      transition: background 0.2s;
    }
    .step:hover { background: var(--surface2); }
    .step-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.8rem;
      line-height: 1;
      color: var(--red);
      opacity: 0.4;
      margin-bottom: 0.8rem;
    }
    .step h3 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.3rem;
      color: var(--text);
      margin-bottom: 0.5rem;
    }
    .step p { font-size: 0.88rem; color: var(--muted); line-height: 1.7; }

    /* ── DIVIDER ── */
    .divider {
      border: none;
      border-top: 1px solid var(--border);
      max-width: 940px;
      margin: 0 auto;
    }

    /* ── FORM ── */
    #reservar { scroll-margin-top: 2rem; }

    .form-wrap {
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 3rem 2.5rem;
      margin-top: 3rem;
      position: relative;
      overflow: hidden;
    }
    .form-wrap::after {
      content: '';
      position: absolute;
      top: -80px; right: -80px;
      width: 240px; height: 240px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(209,0,10,0.08), transparent 70%);
      pointer-events: none;
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.2rem;
    }
    .form-full { grid-column: 1 / -1; }

    label {
      display: block;
      font-size: 0.73rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.45rem;
    }
    label .opt { color: #bbb; font-size: 0.65rem; letter-spacing: 0; text-transform: none; margin-left: 4px; }

    input, select, textarea {
      width: 100%;
      background: var(--bg);
      border: 1px solid rgba(0,0,0,0.15);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.95rem;
      padding: 0.85rem 1rem;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      appearance: none;
      border-radius: 0;
    }
    input:focus, select:focus, textarea:focus {
      border-color: var(--red);
      box-shadow: 0 0 0 3px var(--red-glow);
    }
    select option { background: #fff; }
    textarea { resize: vertical; min-height: 110px; }

    .form-submit {
      margin-top: 1.8rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .submit-btn {
      background: var(--red);
      color: #fff;
      border: none;
      padding: 1rem 3rem;
      font-family: 'DM Sans', sans-serif;
      font-weight: 500;
      font-size: 0.92rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 0 22px var(--red-glow);
    }
    .submit-btn:hover {
      background: var(--red-dark);
      transform: translateY(-2px);
      box-shadow: 0 0 40px rgba(209,0,10,0.32);
    }
    .submit-note {
      font-size: 0.8rem;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ── SUCCESS ── */
    .success-msg {
      display: none;
      text-align: center;
      padding: 3rem 2rem;
    }
    .success-msg .check { font-size: 3rem; margin-bottom: 1rem; }
    .success-msg h3 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      color: var(--text);
      margin-bottom: 0.5rem;
    }
    .success-msg p { color: var(--muted); font-size: 0.92rem; }

    /* ── FOOTER ── */
    footer {
      background: #111;
      border-top: 1px solid rgba(255,255,255,0.06);
      padding: 3rem 2rem;
      text-align: center;
      color: rgba(255,255,255,0.4);
      font-size: 0.82rem;
      line-height: 2;
    }
    footer strong { color: var(--red); font-weight: 400; }
    footer a { color: rgba(255,255,255,0.5); text-decoration: none; }
    footer a:hover { color: #fff; }
    .footer-wa {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: #25D366;
      font-weight: 500;
      text-decoration: none;
      margin-top: 0.5rem;
    }
    .footer-wa:hover { opacity: 0.8; }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      .form-grid { grid-template-columns: 1fr; }
      .form-full { grid-column: 1; }
      .form-wrap { padding: 2rem 1.4rem; }
      .hero-btns { flex-direction: column; align-items: center; }
    }
  </style>
</head>
